VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# Firebase Web App config (Project settings → General → Your apps → Web app)
# Needed for the expert to get push notifications with sound when the portal
# tab is closed / not logged in. Leave blank to disable push (the in-tab
# ringtone banner still works via socket while the portal is open).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Project settings → Cloud Messaging → Web Push certificates → key pair
VITE_FIREBASE_VAPID_KEY=
